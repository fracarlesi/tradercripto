# Database Configuration (T067)
# Development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/trader.db

# Production (PostgreSQL) - Uncomment and configure for production:
# DATABASE_URL=postgresql+asyncpg://trader:trader_password@postgres:5432/trader_db

# PostgreSQL Configuration (for docker-compose)
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_password
POSTGRES_DB=trader_db

# Hyperliquid Trading Configuration
HYPERLIQUID_PRIVATE_KEY=your_private_key_here
HYPERLIQUID_WALLET_ADDRESS=your_wallet_address_here

# DeepSeek AI Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Debug Settings
DEBUG=false
SQL_DEBUG=false

# Database Pool Configuration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# Sync Configuration
SYNC_INTERVAL_SECONDS=30

# AI Decision Configuration
AI_DECISION_INTERVAL=180
