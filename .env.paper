# =============================================================================
# HLQuantBot - Paper Trading Environment (Testnet)
# =============================================================================
# Copy this file and fill in your testnet credentials.
# Usage: cp .env.paper .env  (when running in paper mode)
# =============================================================================

# Hyperliquid Testnet credentials
ENVIRONMENT=testnet
HYPERLIQUID_PRIVATE_KEY=<testnet_private_key>
WALLET_ADDRESS=<testnet_wallet_address>

# Data directory (separate from production)
HLQUANTBOT_DATA_DIR=/root/.hlquantbot_paper

# Notifications (separate topic for paper trades)
NTFY_TOPIC_PAPER=hlquantbot-paper

# DeepSeek API (same key works for both envs)
DEEPSEEK_API_KEY=<same_key>
